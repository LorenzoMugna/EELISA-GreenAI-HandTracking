# UDP Configuration for EELISA GreenAI Hand Tracking
#
# These are default values. You can override IP/port programmatically:
#   - Sender: udp.configure(ip="...", port=...) or UDPSender(ip="...", port=...)
#   - Receiver: UDPReceiver(data_store, ip="...", port=...)

# Network settings - default addresses
SENDER_IP=10.97.150.2
SENDER_PORT=5005
RECEIVER_IP=10.97.150.1
RECEIVER_PORT=5006
BUFFER_SIZE=65535
TIMEOUT=5

# Spike configuration
# NUM_SPIKE_QUEUES (N): Number of separate spike queues (one per neuron/channel)
NUM_SPIKE_QUEUES=6
# SPIKE_WINDOW_MS (W): Time window in milliseconds for keeping spike timestamps
SPIKE_WINDOW_MS=500
# CLEANUP_INTERVAL_MS: How often the cleanup thread removes old spikes
CLEANUP_INTERVAL_MS=100
